# ============================================
# AssetFlow — Environment Variables
# ============================================
# Copy this file to .env and update the values

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/assetflow?schema=public"

# JWT Secret (used by backend-api branch)
JWT_SECRET="your-super-secret-jwt-key-change-this"

# Server port (used by backend-api branch)
PORT=5000

# Frontend URL for CORS (used by backend-api branch)
FRONTEND_URL="http://localhost:5173"
